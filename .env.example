# ── Central server ───────────────────────────────────────────────
# Postgres / TimescaleDB connection
DATABASE_URL=postgres://mping:mping@localhost:5432/mping

# HTTP server
PORT=4420
HOST=0.0.0.0

# Public URL the UI is reachable at (used in Discord embed links)
PUBLIC_URL=http://localhost:4420

# Session cookie signing secret (>= 32 chars). Generate: openssl rand -hex 32
SESSION_SECRET=change-me-please-to-a-long-random-string-0123456789

# Initial admin password for the web UI (only used to seed on first boot)
ADMIN_PASSWORD=admin

# ── Bundled collector (docker-compose) ───────────────────────────
# The compose stack auto-creates a collector with this name + token and runs a
# local agent against it, so `docker compose up` works out of the box.
# CHANGE THE TOKEN for any real deployment.
COLLECTOR_NAME=local
COLLECTOR_TOKEN=local-bootstrap-token-change-me

# ── Standalone agent (run outside compose) ───────────────────────
# Read by packages/agent when run directly (pnpm dev:agent / systemd).
MPING_SERVER=http://localhost:4420
MPING_TOKEN=replace-with-collector-token
MPING_NAME=local
